{
	"name": "reka",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "concurrently -n app,storybook -c blue,magenta \"react-router dev\" \"npm run storybook\"",
		"start": "react-router-serve ./build/server/index.js",
		"typecheck": "react-router typegen && tsc",
		"storybook": "storybook dev -p 6006 --no-open",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.4.0",
		"@react-router/node": "8.0.0",
		"@react-router/serve": "8.0.0",
		"firebase": "^12.16.0",
		"isbot": "^5.1.36",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.81.0",
		"react-router": "8.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@react-router/dev": "8.0.0",
		"@storybook/addon-a11y": "^10.5.0",
		"@storybook/addon-docs": "^10.5.0",
		"@storybook/addon-onboarding": "^10.5.0",
		"@storybook/addon-vitest": "^10.5.0",
		"@storybook/react-vite": "^10.5.0",
		"@types/node": "^22",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"concurrently": "^10.0.3",
		"playwright": "^1.61.1",
		"sass": "^1.101.0",
		"storybook": "^10.5.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.3",
		"vitest": "^4.1.10"
	}
}
